# Copy this file to `.env` and fill in. NEVER commit `.env`.

# ---------- Local MSSQL (on your Windows 10 PC, reachable via Tailscale) ----------
MSSQL_HOST=tail5d65d5.ts.net
MSSQL_PORT=1433
MSSQL_DB=skybird
MSSQL_USER=sa
MSSQL_PASSWORD=CHANGE_ME
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# ---------- Supabase (cloud — same project as the React/HTML app) ----------
SUPABASE_URL=https://zshyqwviuuhplgyiatdw.supabase.co
# Use the SERVICE ROLE key so the bridge bypasses RLS.
# Get it from Supabase Dashboard -> Project Settings -> API -> service_role.
# Keep it secret — anyone with this key can read/write everything.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# ---------- Sync behaviour ----------
SYNC_INTERVAL_SECONDS=60
# Direction: "two-way" | "push" (MSSQL->Supabase only) | "pull" (Supabase->MSSQL only)
SYNC_DIRECTION=two-way
